[Unit]
Description=Celestial Scale Kiosk (NAU7802 ADC)
# Disable celestial-scale-hx711.service before enabling this one.

[Service]
Type=simple
User=oas
Group=oas
WorkingDirectory=/home/oas/celestial_scale
EnvironmentFile=/etc/celestial-env
Environment=DISPLAY=:0
Environment=NO_AT_BRIDGE=1

StandardOutput=journal
StandardError=journal

ExecStart=/usr/bin/xinit /usr/bin/python3 /home/oas/celestial_scale/celestial_scale.py --adc nau7802 -- :0 vt1 -nolisten tcp

Nice=-20
IOSchedulingClass=realtime
WatchdogSec=30
NotifyAccess=all
Restart=always
RestartSec=5
SupplementaryGroups=video input render tty gpio

[Install]
WantedBy=multi-user.target
